---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Niirmaan Growth Hub | Web Design Agency",
  description = "We build high-converting, mobile-friendly websites that attract customers, build trust and grow your business 24/7."
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/NGH_LOGO.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-poppins bg-white text-gray-900 antialiased overflow-x-hidden pt-12 sm:pt-14 md:pt-16">
    <slot />
  </body>
</html>
