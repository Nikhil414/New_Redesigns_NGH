---
import SectionHeading from './SectionHeading.astro';

const steps = [
  { number: "1", color: "bg-blue-500", title: "Book a Free Consultation", desc: "Schedule a call with our experts." },
  { number: "2", color: "bg-pink-500", title: "We Analyze Your Business Goals", desc: "We understand your business, audience & competition." },
  { number: "3", color: "bg-orange-400", title: "Receive a Custom Website Strategy", desc: "Get a personalised plan to grow your business online." },
  { number: "4", color: "bg-purple-500", title: "Design & Development", desc: "We design, develop and refine your website." },
  { number: "5", color: "bg-green-500", title: "Launch & Growth Support", desc: "We launch and provide ongoing support for continuous growth." },
];
---
<section id="process" class="py-10 bg-white">
  <div class="max-w-6xl mx-auto px-4">
    <SectionHeading title="OUR PROCESS" />
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-5">
      {steps.map(step => (
        <div class="bg-white border border-gray-100 rounded-xl p-5 shadow-sm text-center hover:shadow-md transition-shadow">
          <div class={`w-10 h-10 rounded-full ${step.color} flex items-center justify-center text-white font-bold text-sm mx-auto mb-3`}>
            {step.number}
          </div>
          <h3 class="text-sm font-semibold text-gray-800 mb-1.5">{step.title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
