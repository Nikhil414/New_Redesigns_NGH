---
const socials = [
  { label: "f", title: "Facebook", href: "#" },
  { label: "in", title: "Instagram", href: "#" },
  { label: "t", title: "Twitter", href: "#" },
  { label: "li", title: "LinkedIn", href: "#" },
];

const quickLinks = [
  { label: "Home", href: "#home" },
  { label: "Services", href: "#services" },
  { label: "Portfolio", href: "#results" },
  { label: "Process", href: "#process" },
  { label: "About Us", href: "#about" },
  { label: "FAQs", href: "#faq" },
];
---

<footer id="booking" class="bg-gray-900 text-white">

  <!-- Top CTA Band -->
  <div class="bg-gradient-to-r from-pink-500 via-orange-400 to-yellow-400 py-8">
    <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-4 text-center md:text-left">
      <div>
        <h2 class="text-2xl md:text-3xl font-extrabold text-white leading-tight">
          Ready to Grow Your Business Online?
        </h2>
        <p class="text-white/80 text-sm mt-1">Let's build something great together — free consultation, no strings attached.</p>
      </div>
      <a
        href="https://calendly.com/nirale-niirmaangrowthhub/free-website-audit-growth-strategy-call?month=2026-06"
        target="_blank"
        rel="noopener noreferrer"
        class="w-full md:w-auto text-center bg-white text-orange-500 font-bold text-base px-7 py-4 rounded-full hover:bg-gray-100 transition-colors shadow-md"
      >
        📅 Book Free Consultation
      </a>
    </div>
  </div>

  <!-- Main Footer Grid -->
  <div class="max-w-6xl mx-auto px-4 py-10 grid grid-cols-1 sm:grid-cols-3 gap-8">

    <!-- Brand Column -->
    <div>
      <img src="/NGH_LOGO.png" alt="Niirmaan Growth Hub" class="h-20 w-auto mb-4" />
      <p class="text-gray-400 text-sm leading-relaxed mb-5">
        360° Digital Solutions Agency helping businesses grow with smart, conversion-focused digital strategies.
      </p>
      <div class="flex items-center gap-2">
        {socials.map(s => (
          <a
            href={s.href}
            title={s.title}
            class="w-9 h-9 rounded-full border border-gray-700 flex items-center justify-center text-gray-400 text-xs font-bold hover:border-orange-400 hover:text-orange-400 transition-colors"
          >
            {s.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Quick Links Column -->
    <div>
      <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-5">Quick Links</h4>
      <ul class="space-y-2.5">
        {quickLinks.map(link => (
          <li>
            <a href={link.href} class="text-gray-400 text-sm hover:text-orange-400 transition-colors flex items-center gap-2">
              <span class="w-1 h-1 rounded-full bg-orange-400 shrink-0"></span>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact Column -->
    <div>
      <h4 class="text-white font-bold text-sm uppercase tracking-widest mb-5">Get In Touch</h4>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-0.5 text-orange-400 text-base">📧</span>
          <div>
            <div class="text-sm text-gray-500 mb-0.5">Email</div>
            <a href="mailto:hello@niirmaangrowth.com" class="text-gray-300 text-sm hover:text-orange-400 transition-colors">hello@niirmaangrowth.com</a>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-0.5 text-orange-400 text-base">📞</span>
          <div>
            <div class="text-sm text-gray-500 mb-0.5">Phone</div>
            <a href="tel:+911234567890" class="text-gray-300 text-sm hover:text-orange-400 transition-colors">+91 12345 67890</a>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-0.5 text-orange-400 text-base">📍</span>
          <div>
            <div class="text-sm text-gray-500 mb-0.5">Location</div>
            <span class="text-gray-300 text-sm">India</span>
          </div>
        </li>
      </ul>
    </div>

  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-6xl mx-auto px-4 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-500">
      <span>&copy; 2026 Niirmaan Growth Hub. All rights reserved.</span>
      <a href="/privacy-policy" class="text-orange-400 font-semibold text-xs underline underline-offset-2 hover:text-orange-300 transition-colors">Privacy &amp; Policy</a>
      <span class="flex items-center gap-1">
        Built with
        <span class="text-orange-400 font-semibold">♥</span>
        for growing businesses
      </span>
    </div>
  </div>

</footer>
