---
const benefits = [
  {
    icon: "🎯",
    title: "Strategy First",
    desc: "We don't just build websites — we build strategies for generating enquiries and sales.",
  },
  {
    icon: "💡",
    title: "Conversion Focused",
    desc: "Every page is designed to generate enquiries and sales.",
  },
  {
    icon: "📱",
    title: "Mobile Optimized",
    desc: "Your website will look perfect on all devices.",
  },
  {
    icon: "⚡",
    title: "Fast Delivery",
    desc: "Get your website live in as little as 7 days.",
  },
  {
    icon: "🤝",
    title: "Ongoing Support",
    desc: "We're here even after your website goes live.",
  },
];
---
<section id="about" class="py-16 bg-gradient-to-r from-pink-500 to-orange-400">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col lg:flex-row gap-10 items-start">

      <!-- Left: Title -->
      <div class="lg:w-1/3">
        <h2 class="text-2xl lg:text-3xl font-extrabold text-white leading-tight">
          WHY CHOOSE<br />NIIRMAAN<br />GROWTH HUB?
        </h2>
        <div class="w-12 h-1 bg-white mt-4 rounded"></div>
      </div>

      <!-- Right: Benefits -->
      <div class="lg:w-2/3 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map(benefit => (
          <div class="flex items-start gap-3">
            <span class="text-2xl">{benefit.icon}</span>
            <div>
              <h3 class="text-white font-semibold text-sm mb-1">{benefit.title}</h3>
              <p class="text-orange-100 text-xs leading-relaxed">{benefit.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
