---
const navLinks = [
  { label: "Home", href: "#home" },
  { label: "Services", href: "#services" },
  { label: "Portfolio", href: "#results" },
  { label: "Process", href: "#process" },
  { label: "About Us", href: "#about" },
  { label: "FAQs", href: "#faq" },
];
---
<nav class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">

    <!-- Logo -->
    <a href="#home" class="flex items-center">
      <img src="/NGH_LOGO.png" alt="Niirmaan Growth Hub" class="h-20 w-auto object-contain drop-shadow-sm" />
    </a>

    <!-- Mobile tagline (only visible on mobile) -->
    <div class="flex md:hidden flex-col items-start ml-2">
      <span class="text-xs font-bold text-gray-800 uppercase leading-tight tracking-tight">Free Website Audit +</span>
      <span class="text-xs font-bold text-orange-500 uppercase leading-tight tracking-tight">Growth Strategy Call</span>
    </div>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-6">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="text-sm text-gray-700 hover:text-orange-500 font-medium transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA -->
    <a
      href="#booking"
      class="hidden md:inline-flex items-center gap-1.5 bg-gradient-to-r from-pink-500 via-orange-400 to-yellow-400 text-white text-xs font-semibold rounded-full px-4 py-2.5 hover:opacity-90 transition-opacity"
    >
      📅 Book Free Consultation
    </a>

    <!-- Mobile hamburger -->
    <button id="nav-toggle" class="md:hidden p-2 text-gray-700 hover:text-orange-500" aria-label="Toggle menu" aria-expanded="false">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="nav-menu" class="hidden md:hidden bg-white border-t border-gray-100 px-4 pb-4 pt-2">
    {navLinks.map(link => (
      <a href={link.href} class="block py-3 text-base text-gray-700 hover:text-orange-500 font-medium border-b border-gray-50">
        {link.label}
      </a>
    ))}
    <a
      href="#booking"
      class="mt-3 block text-center bg-gradient-to-r from-pink-500 via-orange-400 to-yellow-400 text-white text-base font-semibold rounded-full px-5 py-3 hover:opacity-90"
    >
      📅 Book Free Consultation
    </a>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
  });
</script>
