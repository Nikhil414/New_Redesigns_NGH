---
const testimonials = [
  {
    quote: "Niirmaan Growth Hub built an amazing website for our business. We started getting quality leads just weeks after launch!",
    name: "Rohit Sharma",
    role: "Real Estate Consultant",
    initials: "RS",
  },
  {
    quote: "Professional team, fast delivery and excellent support. Highly recommended!",
    name: "Anita Verma",
    role: "Life Coach",
    initials: "AV",
  },
  {
    quote: "Our online sales increased significantly after the new website. Great work by the team!",
    name: "Kunal Mehta",
    role: "E-Commerce Entrepreneur",
    initials: "KM",
  },
];
---
<section class="py-16 bg-sky-50">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col lg:flex-row gap-10 items-start">

      <!-- Left: heading -->
      <div class="lg:w-1/4">
        <p class="text-xs font-semibold text-orange-500 uppercase tracking-widest mb-2">Testimonials</p>
        <h2 class="text-2xl font-extrabold text-gray-900 leading-tight">WHAT OUR<br />CLIENTS SAY</h2>
        <div class="w-10 h-1 bg-orange-400 mt-3 rounded"></div>
        <div class="flex mt-5">
          {[1,2,3,4,5].map(() => <span class="text-yellow-400 text-lg">★</span>)}
        </div>
        <p class="text-xs text-gray-500 mt-1">4.9 from 720+ Clients</p>
      </div>

      <!-- Right: cards -->
      <div class="lg:w-3/4 grid grid-cols-1 md:grid-cols-3 gap-5">
        {testimonials.map(t => (
          <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100">
            <div class="flex mb-3">
              {[1,2,3,4,5].map(() => <span class="text-yellow-400 text-sm">★</span>)}
            </div>
            <p class="text-sm text-gray-600 mb-4 leading-relaxed">"{t.quote}"</p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-pink-500 to-orange-400 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                {t.initials}
              </div>
              <div>
                <div class="text-sm font-semibold text-gray-800">{t.name}</div>
                <div class="text-xs text-gray-500">{t.role}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
