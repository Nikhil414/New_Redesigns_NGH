---
import SectionHeading from './SectionHeading.astro';

const painPoints = [
  {
    image: "/Professional_Website.png",
    title: "No Professional Website",
    desc: "Customers can't find you online.",
    accent: "border-red-400",
    badge: "bg-red-100 text-red-500",
  },
  {
    image: "/Outdated_Website.png",
    title: "Outdated Website That Doesn't Convert",
    desc: "Old design = lost trust and sales.",
    accent: "border-orange-400",
    badge: "bg-orange-100 text-orange-500",
  },
  {
    image: "/Slow_Loading_Website.png",
    title: "Slow Loading Pages",
    desc: "Slow websites lose visitors instantly.",
    accent: "border-yellow-400",
    badge: "bg-yellow-100 text-yellow-600",
  },
  {
    image: "/No_Leads.png",
    title: "No Leads From Online Searches",
    desc: "You're invisible where it matters most.",
    accent: "border-blue-400",
    badge: "bg-blue-100 text-blue-500",
  },
  {
    image: "/Customer_Choose.png",
    title: "Customers Choose Competitors",
    desc: "They go with the business that looks professional.",
    accent: "border-purple-400",
    badge: "bg-purple-100 text-purple-500",
  },
];
---
<section class="py-12 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <SectionHeading title="IS YOUR BUSINESS LOSING CUSTOMERS ONLINE?" />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5">
      {painPoints.map(point => (
        <div class={`bg-white rounded-2xl shadow-sm border-t-4 ${point.accent} overflow-hidden hover:shadow-md transition-shadow flex flex-col`}>
          <!-- Image -->
          <div class="w-full h-44 bg-gray-950 flex items-center justify-center overflow-hidden">
            <img
              src={point.image}
              alt={point.title}
              class="w-full h-full object-contain"
              loading="lazy"
            />
          </div>
          <!-- Text -->
          <div class="p-4 flex flex-col flex-1">
            <h3 class="text-base font-bold text-gray-800 mb-1.5 leading-snug">{point.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{point.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
