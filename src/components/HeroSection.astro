---
import GradientButton from './GradientButton.astro';

const features = [
  { icon: "📱", label: "Mobile\nResponsive" },
  { icon: "🔍", label: "SEO\nReady" },
  { icon: "⚡", label: "Fast\nLoading" },
  { icon: "🎯", label: "Lead\nGeneration" },
  { icon: "💬", label: "WhatsApp\nIntegration" },
];
---
<section id="home" class="bg-sky-50 py-10 lg:py-12">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex flex-col lg:flex-row items-center gap-8">

      <!-- Left: Text -->
      <div class="flex-1 max-w-xl">
        <div class="inline-flex items-center gap-2 bg-white text-sm font-medium text-gray-600 px-4 py-2 rounded-full shadow-sm mb-3 border border-gray-100">
          <span class="w-2 h-2 bg-green-400 rounded-full inline-block"></span>
          360° DIGITAL SOLUTIONS AGENCY
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 leading-tight mb-4">
          GET A WEBSITE THAT<br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 to-orange-400">
            GENERATES LEADS
          </span><br />
          &amp; SALES
        </h1>

        <p class="text-gray-600 text-base mb-4">
          We build high-converting, mobile-friendly websites that attract customers,
          build trust and grow your business 24/7.
        </p>

        <!-- Feature icons -->
        <div class="grid grid-cols-5 gap-2 mb-5">
          {features.map(f => (
            <div class="flex flex-col items-center gap-1 text-center">
              <span class="text-xl sm:text-2xl">{f.icon}</span>
              <span class="text-xs sm:text-sm text-gray-600 font-medium whitespace-pre-line leading-tight">{f.label}</span>
            </div>
          ))}
        </div>

        <GradientButton href="#booking" class="w-full sm:w-auto px-8 py-4 text-base font-bold mb-3">
          📅 BOOK FREE CONSULTATION
        </GradientButton>

        <p class="text-sm text-gray-400 mt-3">Free Website Audit + Growth Strategy Session</p>
      </div>

      <!-- Right: Device mockup (hidden on small mobile, shown from sm up) -->
      <div class="flex-1 hidden sm:flex justify-center lg:justify-end">
        <div class="relative w-full max-w-sm lg:max-w-md pb-6">

          <!-- Laptop screen mockup -->
          <div class="bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden">
            <!-- Browser chrome -->
            <div class="bg-gray-100 px-3 py-2 flex items-center gap-1.5">
              <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-yellow-400"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-green-400"></span>
              <div class="flex-1 bg-white rounded text-xs text-gray-400 text-center py-0.5 ml-2 px-2 truncate">
                We Create Websites That Drive Growth
              </div>
            </div>
            <!-- Page content area -->
            <div class="bg-gradient-to-br from-blue-600 to-blue-800 p-6 text-white text-center">
              <div class="text-base font-bold mb-1">We Create Websites</div>
              <div class="text-xs opacity-80 mb-3">That Drive Growth</div>
              <span class="inline-block bg-white text-blue-700 text-xs font-semibold px-3 py-1 rounded-full">
                Get Started
              </span>
            </div>
            <div class="p-4 bg-white">
              <div class="grid grid-cols-4 gap-2">
                {['Website Design', 'High Performance', 'SEO Approved', 'Custom Solutions'].map(item => (
                  <div class="bg-gray-50 rounded p-2 text-center text-xs text-gray-500">{item}</div>
                ))}
              </div>
            </div>
          </div>

          <!-- Mobile mockup (overlapping) -->
          <div class="absolute -bottom-4 -right-4 w-28 bg-white rounded-2xl shadow-xl border border-gray-200 overflow-hidden">
            <div class="bg-gradient-to-br from-blue-600 to-blue-800 p-3 text-white text-center">
              <div class="text-xs font-bold">We Create</div>
              <div class="text-xs opacity-75">Websites</div>
            </div>
            <div class="p-2 bg-white space-y-1.5">
              <div class="h-1.5 bg-gray-200 rounded"></div>
              <div class="h-1.5 bg-gray-200 rounded w-3/4"></div>
              <div class="h-1.5 bg-gray-200 rounded w-1/2"></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
