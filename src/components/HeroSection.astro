---
import GradientButton from './GradientButton.astro';

const features = [
  { icon: "📱", label: "Mobile\nResponsive" },
  { icon: "🔍", label: "SEO\nReady" },
  { icon: "⚡", label: "Fast\nLoading" },
  { icon: "🎯", label: "Lead\nGeneration" },
  { icon: "💬", label: "WhatsApp\nIntegration" },
];
---

<section id="home" class="relative bg-sky-50 py-12 lg:py-16 overflow-hidden">

  <!-- Background decorative blobs -->
  <div class="absolute top-0 left-0 w-72 h-72 bg-pink-200 opacity-30 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-orange-200 opacity-25 rounded-full blur-3xl translate-x-1/3 translate-y-1/3 pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/2 w-64 h-64 bg-sky-200 opacity-20 rounded-full blur-2xl -translate-x-1/2 -translate-y-1/2 pointer-events-none"></div>

  <!-- Dot grid overlay -->
  <div class="absolute inset-0 opacity-[0.06] pointer-events-none" style="background-image: radial-gradient(circle, #64748b 1px, transparent 1px); background-size: 28px 28px;"></div>

  <div class="relative max-w-6xl mx-auto px-4">
    <div class="flex flex-col md:flex-row items-center gap-10 lg:gap-14">

      <!-- Left: Text -->
      <div class="flex-1 max-w-xl">

        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-white text-sm font-semibold text-gray-700 px-4 py-2 rounded-full shadow-md mb-5 border border-orange-100">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
          </span>
          360° DIGITAL SOLUTIONS AGENCY
        </div>

        <!-- Headline -->
        <h1 class="text-4xl sm:text-4xl lg:text-5xl font-extrabold text-gray-900 leading-tight mb-5">
          GET A WEBSITE THAT<br />
          <span class="relative inline-block">
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 via-orange-400 to-yellow-400">
              GENERATES LEADS
            </span>
            <!-- Underline accent -->
            <span class="absolute -bottom-1 left-0 w-full h-1 rounded-full bg-gradient-to-r from-pink-400 to-orange-300 opacity-60"></span>
          </span>
          <br />
          &amp; SALES
        </h1>

        <!-- Subtext -->
        <p class="text-gray-600 text-base lg:text-lg mb-6 leading-relaxed">
          We build high-converting, mobile-friendly websites that attract customers,
          build trust and grow your business <strong class="text-gray-800">24/7.</strong>
        </p>

        <!-- Feature chips -->
        <div class="flex flex-wrap gap-2 mb-7">
          {features.map(f => (
            <div class="flex items-center gap-1.5 bg-white border border-gray-100 shadow-sm rounded-full px-3 py-1.5 text-xs font-semibold text-gray-700 hover:shadow-md hover:border-orange-200 transition-all">
              <span class="text-base">{f.icon}</span>
              <span class="whitespace-nowrap">{f.label.replace('\n', ' ')}</span>
            </div>
          ))}
        </div>

        <!-- CTA -->
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
          <GradientButton href="https://calendly.com/nirale-niirmaangrowthhub/free-website-audit-growth-strategy-call?month=2026-06" class="px-8 py-4 text-base font-bold shadow-lg hover:shadow-orange-300/50 transition-shadow">
            📅 BOOK FREE CONSULTATION
          </GradientButton>
        </div>

        <!-- Trust line -->
        <div class="flex items-center gap-2 mt-4">
          <span class="text-yellow-400 text-sm">★★★★★</span>
          <p class="text-sm text-gray-500 font-medium">Free Website Audit + Growth Strategy Session</p>
        </div>

      </div>

      <!-- Right: Image with glow and float -->
      <div class="flex-1 hidden sm:flex justify-center md:justify-end">
        <div class="relative">
          <!-- Glow ring behind image -->
          <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-pink-300 via-orange-200 to-yellow-200 opacity-40 blur-2xl scale-110 pointer-events-none"></div>

          <!-- Image -->
          <img
            src="/Perfect_image.png"
            alt="Niirmaan Growth Hub"
            class="relative w-full max-w-lg lg:max-w-xl object-contain drop-shadow-2xl hero-float"
          />

          <!-- Floating badge bottom-right -->
          <div class="absolute -bottom-4 -right-4 bg-white rounded-2xl shadow-xl px-4 py-2.5 flex items-center gap-2 border border-gray-100">
            <span class="text-xl">📈</span>
            <div>
              <p class="text-xs font-bold text-gray-800 leading-none">3x More Leads</p>
              <p class="text-[10px] text-gray-500 mt-0.5">Avg. client result</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-float {
    animation: heroFloat 4s ease-in-out infinite;
  }
  @keyframes heroFloat {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-10px); }
  }
</style>
