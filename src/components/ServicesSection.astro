---
import SectionHeading from './SectionHeading.astro';

const services = [
  {
    color: "text-blue-500",
    path: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
    title: "Business Websites",
    desc: "Professional websites designed to establish credibility and generate enquiries.",
  },
  {
    color: "text-orange-500",
    path: "M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z",
    title: "E-Commerce Stores",
    desc: "Sell products online with secure payment gateways and optimized checkout flows.",
  },
  {
    color: "text-green-500",
    path: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
    title: "Landing Pages",
    desc: "Conversion-focused pages built specifically for lead generation and campaigns.",
  },
  {
    color: "text-purple-500",
    path: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
    title: "Custom Web Solutions",
    desc: "Tailored websites and web applications built around your unique business needs.",
  },
];
---
<section id="services" class="py-16 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4">
    <SectionHeading title="WHAT WE BUILD" />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map(service => (
        <div class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
          <div class={`mb-4 ${service.color}`}>
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={service.path} />
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-gray-800 mb-2">{service.title}</h3>
          <p class="text-xs text-gray-500 leading-relaxed">{service.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
