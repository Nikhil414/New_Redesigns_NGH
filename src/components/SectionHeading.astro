---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---
<div class="text-center mb-7">
  <h2 class="text-3xl sm:text-3xl font-extrabold text-gray-900 mb-3">{title}</h2>
  {subtitle && <p class="text-gray-500 max-w-xl mx-auto text-base sm:text-base">{subtitle}</p>}
</div>
