---
interface Props {
  href?: string;
  class?: string;
}
const { href, class: className = "" } = Astro.props;
const base = `inline-flex items-center justify-center gap-2 bg-gradient-to-r from-pink-500 via-orange-400 to-yellow-400 text-white font-semibold rounded-full px-6 py-3 hover:opacity-90 transition-opacity text-sm ${className}`;
---
{href
  ? <a href={href} class={base}><slot /></a>
  : <button class={base}><slot /></button>
}
