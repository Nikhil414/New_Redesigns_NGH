---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Thank You | Niirmaan Growth Hub" description="Your strategy call is confirmed. We look forward to helping your business grow online.">

  <div class="min-h-screen bg-gradient-to-br from-pink-50 via-white to-orange-50 flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-lg bg-white rounded-3xl shadow-xl px-6 py-10 sm:px-10 text-center">

      <!-- Checkmark -->
      <div class="relative inline-flex items-center justify-center mb-5">
        <!-- Confetti dots -->
        <span class="absolute -top-3 -left-4 w-2 h-2 rounded-full bg-pink-400 opacity-70"></span>
        <span class="absolute -top-1 right-0 w-1.5 h-1.5 rounded-full bg-yellow-400 opacity-80"></span>
        <span class="absolute top-2 -right-5 w-2 h-2 rounded-full bg-orange-400 opacity-60"></span>
        <span class="absolute -bottom-2 -left-5 w-1.5 h-1.5 rounded-full bg-green-400 opacity-70"></span>
        <span class="absolute bottom-0 right-2 w-2 h-2 rounded-full bg-pink-300 opacity-60"></span>
        <div class="w-20 h-20 rounded-full bg-green-50 border-2 border-green-100 flex items-center justify-center">
          <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
          </svg>
        </div>
      </div>

      <!-- Heading -->
      <h1 class="text-5xl sm:text-6xl font-extrabold leading-tight mb-2">
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-500 via-orange-400 to-yellow-400">Thank You!</span>
      </h1>
      <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mb-3">
        Your Strategy Call is Confirmed 🎉
      </h2>
      <p class="text-gray-500 text-sm sm:text-base leading-relaxed mb-7">
        We've sent the meeting details to your email.<br />
        We look forward to helping your business grow online.
      </p>

      <!-- Date & Time card -->
      <div class="bg-gray-50 border border-gray-100 rounded-2xl p-5 grid grid-cols-2 divide-x divide-gray-200 mb-7">
        <div class="flex items-center gap-3 pr-4">
          <div class="w-10 h-10 rounded-full bg-pink-50 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <div class="text-left">
            <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-0.5">Date</div>
            <div class="text-sm font-bold text-gray-800">See Calendar Invite</div>
          </div>
        </div>
        <div class="flex items-center gap-3 pl-4">
          <div class="w-10 h-10 rounded-full bg-pink-50 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div class="text-left">
            <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-0.5">Time</div>
            <div class="text-sm font-bold text-gray-800">See Calendar Invite</div>
          </div>
        </div>
      </div>

      <!-- What's Next -->
      <h3 class="text-lg font-bold text-gray-900 mb-5">What's Next?</h3>
      <div class="grid grid-cols-3 gap-4 mb-7">

        <!-- Step 1 -->
        <div class="flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-full bg-pink-50 flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <p class="text-xs font-bold text-pink-500 mb-1">1. Check Email</p>
          <p class="text-xs text-gray-500 leading-snug">Check your email for meeting details and calendar invite.</p>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-full bg-orange-50 flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <p class="text-xs font-bold text-orange-500 mb-1">2. Add to Calendar</p>
          <p class="text-xs text-gray-500 leading-snug">Add the call to your calendar so you don't miss it.</p>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-center text-center">
          <div class="w-12 h-12 rounded-full bg-yellow-50 flex items-center justify-center mb-2">
            <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.069A1 1 0 0121 8.868v6.264a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <p class="text-xs font-bold text-yellow-500 mb-1">3. Join the Call</p>
          <p class="text-xs text-gray-500 leading-snug">Join the call at the scheduled time using the meeting link.</p>
        </div>
      </div>

      <!-- WhatsApp Card -->
      <div class="bg-gradient-to-r from-pink-50 to-orange-50 border border-orange-100 rounded-2xl p-5 flex flex-col sm:flex-row items-center gap-4 mb-7 text-left">
        <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" alt="WhatsApp" class="w-14 h-14 shrink-0" />
        <div class="flex-1 text-center sm:text-left">
          <h4 class="text-base font-bold text-gray-900 mb-1">Stay Connected on WhatsApp</h4>
          <p class="text-sm text-gray-500 mb-3">Join our WhatsApp community for tips, resources and updates.</p>
          <a
            href="https://wa.me/919876543210"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 w-full sm:w-auto bg-gradient-to-r from-pink-500 via-orange-400 to-yellow-400 text-white text-sm font-bold px-6 py-3 rounded-full hover:opacity-90 transition-opacity"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            JOIN WHATSAPP COMMUNITY
          </a>
        </div>
      </div>

      <!-- Footer note -->
      <p class="text-sm text-gray-400">
        <span class="text-pink-400">♥</span> We appreciate your trust in Niirmaan Growth Hub.<br />
        Let's build something amazing together!
      </p>

    </div>
  </div>

</BaseLayout>
