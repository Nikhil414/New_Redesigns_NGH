---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Thank You | Niirmaan Growth Hub" description="Your strategy call is confirmed.">

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-8px); }
  }
  @keyframes pop {
    0% { transform: scale(0.5); opacity: 0; }
    70% { transform: scale(1.1); }
    100% { transform: scale(1); opacity: 1; }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .anim-pop  { animation: pop 0.5s ease-out forwards; }
  .anim-up-1 { animation: fadeUp 0.5s ease-out 0.15s both; }
  .anim-up-2 { animation: fadeUp 0.5s ease-out 0.30s both; }
  .anim-up-3 { animation: fadeUp 0.5s ease-out 0.45s both; }
  .anim-up-4 { animation: fadeUp 0.5s ease-out 0.60s both; }
  .anim-up-5 { animation: fadeUp 0.5s ease-out 0.75s both; }
  .float     { animation: float 3s ease-in-out infinite; }
</style>

<div class="min-h-screen flex flex-col items-center justify-start bg-gradient-to-br from-violet-50 via-white to-pink-50 px-4 pt-8 pb-12">

  <!-- Card -->
  <div class="w-full max-w-[520px] bg-white rounded-[2rem] shadow-2xl overflow-hidden anim-up-2">

    <!-- Top gradient band -->
    <div class="h-2 w-full bg-gradient-to-r from-pink-500 via-orange-400 to-yellow-400"></div>

    <div class="px-7 sm:px-10 pt-8 pb-10 text-center">

      <!-- Checkmark with confetti -->
      <div class="relative inline-flex items-center justify-center mb-5 anim-pop">
        <!-- confetti pieces -->
        <span class="absolute" style="top:-22px;left:16px;width:20px;height:6px;border-radius:4px;background:#f472b6;transform:rotate(-35deg);"></span>
        <span class="absolute" style="top:-16px;right:10px;width:16px;height:5px;border-radius:4px;background:#fbbf24;transform:rotate(28deg);"></span>
        <span class="absolute" style="top:6px;left:-26px;width:18px;height:5px;border-radius:4px;background:#fb923c;transform:rotate(-18deg);"></span>
        <span class="absolute" style="top:6px;right:-28px;width:18px;height:5px;border-radius:4px;background:#a78bfa;transform:rotate(22deg);"></span>
        <span class="absolute rounded-full" style="top:-10px;left:-22px;width:8px;height:8px;background:#ec4899;"></span>
        <span class="absolute rounded-full" style="bottom:-6px;left:-16px;width:6px;height:6px;background:#fbbf24;"></span>
        <span class="absolute rounded-full" style="bottom:-8px;right:-12px;width:7px;height:7px;background:#34d399;"></span>
        <span class="absolute rounded-full" style="top:-14px;right:-8px;width:6px;height:6px;background:#60a5fa;"></span>
        <!-- circle -->
        <div class="float w-[90px] h-[90px] rounded-full bg-green-50 ring-4 ring-green-100 flex items-center justify-center shadow-md">
          <svg class="w-11 h-11 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.8" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
      </div>

      <!-- Heading -->
      <h1 class="font-extrabold leading-none mb-2 anim-up-2" style="font-size:clamp(2.8rem,9vw,3.8rem);background:linear-gradient(90deg,#ec4899 0%,#f97316 50%,#eab308 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">
        Thank You!
      </h1>
      <h2 class="text-lg sm:text-xl font-extrabold text-gray-900 mb-2 anim-up-2">
        Your Strategy Call is Confirmed&nbsp;🎉
      </h2>

      <!-- WhatsApp CTA -->
      <div class="anim-up-4 rounded-2xl overflow-hidden mb-7 border border-green-100">
        <div class="bg-gradient-to-r from-green-50 to-emerald-50 px-5 py-4 flex items-center gap-4">
          <div class="shrink-0 w-12 h-12">
            <svg viewBox="0 0 175.216 175.552" xmlns="http://www.w3.org/2000/svg">
              <defs><linearGradient id="wg" x1="85.915" x2="86.535" y1="32.567" y2="137.092" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#57d163"/><stop offset="1" stop-color="#23b33a"/></linearGradient></defs>
              <path d="M87.184 25.227c-33.733 0-61.166 27.423-61.178 61.13a60.98 60.98 0 0 0 9.349 32.535l1.455 2.313-6.179 22.558 23.146-6.069 2.235 1.324c9.387 5.571 20.15 8.517 31.126 8.523h.023c33.707 0 61.14-27.426 61.153-61.135.013-16.337-6.329-31.693-17.846-43.213-11.519-11.52-26.84-17.876-43.284-17.876z" fill="url(#wg)"/>
              <path d="M68.772 55.603c-1.378-3.061-2.828-3.123-4.137-3.176l-3.524-.043c-1.226 0-3.218.46-4.902 2.3s-6.435 6.287-6.435 15.332 6.588 17.785 7.506 19.013 12.718 20.381 31.405 27.75c15.529 6.124 18.689 4.906 22.061 4.6s10.877-4.447 12.408-8.74 1.532-7.971 1.073-8.74-1.685-1.226-3.524-2.146-10.877-5.367-12.562-5.981-2.91-.919-4.137.921-4.746 5.979-5.819 7.206-2.144 1.381-3.984.462-7.76-2.861-14.784-9.124c-5.465-4.873-9.154-10.891-10.228-12.73s-.114-2.835.808-3.751c.825-.824 1.838-2.147 2.759-3.22s1.224-1.84 1.836-3.065.307-2.301-.153-3.22-4.032-10.011-5.666-13.647z" fill="#fff" fill-rule="evenodd"/>
            </svg>
          </div>
          <div class="text-left">
            <p class="text-sm font-extrabold text-gray-900 leading-tight">Stay Connected on WhatsApp</p>
            <p class="text-xs text-gray-500 mt-0.5">Tips, resources &amp; updates for your business.</p>
          </div>
        </div>
        <a
          href="https://chat.whatsapp.com/EovrjrNnMTV1pE3IEFxH8T?s=cl&p=a&mlu=1"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full bg-gradient-to-r from-pink-500 via-orange-400 to-yellow-400 text-white text-sm font-extrabold tracking-wider py-4 hover:opacity-90 transition-opacity"
        >
          <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          JOIN WHATSAPP COMMUNITY
        </a>
      </div>

      <!-- Footer note -->
      <p class="text-xs text-gray-400 anim-up-5">
        <span class="text-pink-400 text-sm">&#9829;</span>&nbsp;
        We appreciate your trust in <span class="font-semibold text-gray-600">Niirmaan Growth Hub</span>.<br/>
        Let's build something amazing together!
      </p>

    </div>

    <!-- Bottom gradient band -->
    <div class="h-1.5 w-full bg-gradient-to-r from-yellow-400 via-orange-400 to-pink-500"></div>
  </div>

  <!-- Back to home -->
  <a href="/" class="mt-6 text-sm text-gray-400 hover:text-orange-500 transition-colors anim-up-5">
    ← Back to Home
  </a>

</div>

</BaseLayout>
